{
  "name": "p2p-exchange",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @amlbt/web dev",
    "dev:admin": "pnpm --filter @amlbt/admin dev",
    "dev:api": "pnpm --filter @amlbt/api start:dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\""
  },
  "devDependencies": {
    "@amlbt/eslint-config": "workspace:*",
    "@amlbt/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
